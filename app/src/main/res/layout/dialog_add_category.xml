<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCategoryImage"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center"
        android:layout_marginBottom="15dp"
        app:cardCornerRadius="50dp"
        app:cardElevation="2dp">

        <ImageView
            android:id="@+id/ivCategoryDialogImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/lang_food_avt" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="+"
            android:textSize="30sp"
            android:textColor="#757575"
            android:alpha="0.5" />
    </com.google.android.material.card.MaterialCardView>

    <EditText
        android:id="@+id/etCategoryName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tên danh mục (ví dụ: Cơm, Phở)"
        android:inputType="text" />

    <EditText
        android:id="@+id/etCategoryDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Mô tả ngắn gọn"
        android:inputType="text" />

    <!-- Ẩn cái này đi vì mình dùng chọn file -->
    <EditText
        android:id="@+id/etCategoryImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Link ảnh danh mục (URL)"
        android:inputType="textUri"
        android:visibility="gone" />

</LinearLayout>
